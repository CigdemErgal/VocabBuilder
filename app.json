{
  "expo": {
    "name": "VocabBuilder",
    "slug": "VocabBuilder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/illustration.png",
    "scheme": "vocabbuilder",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/illustration.png"
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/illustration.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/illustration.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
